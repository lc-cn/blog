{
  "extends": "@vue/tsconfig/tsconfig.web.json",
  "include": ["env.d.ts","src/vite-env.d.ts", "src/**/*", "src/**/*.vue"],
  "compilerOptions": {
    "baseUrl": ".",
    "importsNotUsedAsValues": "preserve",
    "preserveValueImports": false,
    "noImplicitAny": false,
    "isolatedModules": false,
    "types": [
      "node",
      "global.d.ts",
      "element-plus/global"
    ],
    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "references": [
    {
      "path": "./tsconfig.config.json"
    }
  ]
}
